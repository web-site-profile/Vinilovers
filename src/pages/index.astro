            alt="Kind of Blue vinyl" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-500 flex items-end p-4 opacity-0 group-hover:opacity-100">
            <span class="text-white text-xs font-condensed uppercase tracking-widest">Kind of Blue · Miles Davis</span>
          </div>
        </div>

        <!-- Item 3 — tocadiscos local image -->
        <div class="gallery-item group overflow-hidden border border-surface-bright relative">
