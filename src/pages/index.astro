---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import { getProductos } from '../lib/airtable.js';
import '../styles/global.css';

let productos = [];
try {
  productos = await getProductos();
} catch (e) {
  console.error('Error al obtener productos de Airtable:', e.message);
}

// Detecta el tipo de producto por el nombre (hasta tener campo Categoria en Airtable)
const TIPOS = [
  { palabras: ['vinilo', 'vinyl', 'lp ', ' lp', 'album', 'álbum', 'disco'],   orden: 0 },
  { palabras: ['tocadiscos', 'tornamesa', 'turntable', 'td'],                  orden: 1 },
  { palabras: ['accesorio', 'aguja', 'fono', 'limpia', 'cartridge', 'stylus'], orden: 2 },
  { palabras: ['ropa', 'camiseta', 'tshirt', 'tee', 'merch', 'hoodie'],        orden: 3 },
];

function prioridadNombre(nombre) {
  if (!nombre) return 99;
  const n = nombre.toLowerCase();
  for (const tipo of TIPOS) {
    if (tipo.palabras.some(p => n.includes(p))) return tipo.orden;
  }
  return 98;
}

// Ordenar: primero por tipo detectado del nombre, luego destacados primero dentro del grupo
const productosOrdenados = [...productos].sort((a, b) => {
  const tipoA = prioridadNombre(a.nombre);
  const tipoB = prioridadNombre(b.nombre);
  if (tipoA !== tipoB) return tipoA - tipoB;
  if (b.destacado !== a.destacado) return b.destacado ? 1 : -1;
  // Dentro del mismo tipo, orden alfabético
  return (a.nombre || '').localeCompare(b.nombre || '', 'es');
});
---

<Layout title="Vinilovers - Tienda de Vinilos">

  <Header />

  <!-- ============================================================ -->
  <!-- BEGIN: Hero Section                                           -->
  <!-- ============================================================ -->
  <section class="relative flex items-end pt-20 overflow-hidden" style="height: 85vh; min-height: 580px;">
    <div class="absolute inset-0 z-0 overflow-hidden">
      <video class="w-full h-full object-cover" autoplay muted loop playsinline poster="/portada-video-hero-home.svg">
        <source src="/video-fondo-hero.webm" type="video/webm">
        Tu navegador no soporta video HTML5.
      </video>
      <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/70 to-black/40"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full pb-24">
      <div class="max-w-5xl">
        <p class="font-condensed font-medium text-2xl md:text-3xl uppercase tracking-wide mb-6"
          style="line-height: 1.1; color: #a3211c;">No es solo música,</p>
        <h1 class="text-primary uppercase leading-[0.9] tracking-tight"
          style="font-family: 'Amnestia', sans-serif; font-size: clamp(3rem, 9vw, 7.5rem);">
          ES QUIENES<span class="block mt-6">SOMOS.</span>
        </h1>
        <div class="mt-8">
          <a href="#vinilos"
            class="inline-flex items-center gap-2 font-bold py-3 px-8 rounded-sm uppercase tracking-wider transition-colors text-sm border-2"
            style="color: #a3211c; border-color: #a3211c;"
            onmouseover="this.style.backgroundColor='#a3211c';this.style.color='#fff'"
            onmouseout="this.style.backgroundColor='transparent';this.style.color='#a3211c'">
            Ver colección <i class="fas fa-arrow-right"></i>
          </a>
        </div>
      </div>
    </div>
  </section>
  <!-- END: Hero Section -->

  <!-- ============================================================ -->
  <!-- BEGIN: Marquee                                                -->
  <!-- ============================================================ -->
  <div class="py-4 border-y overflow-hidden flex whitespace-nowrap bg-surface border-surface-container">
    <div class="animate-marquee flex gap-8 items-center text-primary font-display font-bold text-sm tracking-[0.2em] uppercase">
      <span>ROCK</span> <span class="text-[#802020]">•</span> <span>POP</span> <span class="text-[#802020]">•</span>
      <span>SALSA</span> <span class="text-[#802020]">•</span> <span>ACCESORIOS</span> <span class="text-[#802020]">•</span>
      <span>TOCADISCOS</span> <span class="text-[#802020]">•</span> <span>ROPA</span> <span class="text-[#802020]">•</span>
      <span>ROCK</span> <span class="text-[#802020]">•</span> <span>POP</span> <span class="text-[#802020]">•</span>
      <span>SALSA</span> <span class="text-[#802020]">•</span> <span>ACCESORIOS</span> <span class="text-[#802020]">•</span>
      <span>TOCADISCOS</span> <span class="text-[#802020]">•</span> <span>ROPA</span> <span class="text-[#802020]">•</span>
    </div>
    <div aria-hidden="true" class="animate-marquee flex gap-8 items-center text-primary font-display font-bold text-sm tracking-[0.2em] uppercase">
      <span class="ml-8">ROCK</span> <span class="text-[#802020]">•</span> <span>POP</span> <span class="text-[#802020]">•</span>
      <span>SALSA</span> <span class="text-[#802020]">•</span> <span>ACCESORIOS</span> <span class="text-[#802020]">•</span>
      <span>TOCADISCOS</span> <span class="text-[#802020]">•</span> <span>ROPA</span> <span class="text-[#802020]">•</span>
      <span>ROCK</span> <span class="text-[#802020]">•</span> <span>POP</span> <span class="text-[#802020]">•</span>
      <span>SALSA</span> <span class="text-[#802020]">•</span> <span>ACCESORIOS</span> <span class="text-[#802020]">•</span>
      <span>TOCADISCOS</span> <span class="text-[#802020]">•</span> <span>ROPA</span> <span class="text-[#802020]">•</span>
    </div>
  </div>
  <!-- END: Marquee -->

  <!-- ============================================================ -->
  <!-- BEGIN: #vinilos — Catálogo de Vinilos                        -->
  <!-- ============================================================ -->
  <section id="vinilos" class="scroll-mt-24 bg-background">
    <!-- Section Header -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-10">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
        <div class="max-w-2xl">
          <span class="text-[#802020] font-condensed font-semibold tracking-[0.3em] text-xs uppercase block mb-3">
            <i class="fas fa-compact-disc mr-2"></i>Colección
          </span>
          <h2 class="font-display font-bold uppercase text-on-surface mb-4 whitespace-nowrap"
            style="font-size: clamp(1.6rem, 3.5vw, 3.5rem); line-height: 1.05; letter-spacing: -0.02em;">
            Catálogo de <span class="text-primary">Productos</span>
          </h2>
          <p class="text-on-surface-variant text-base md:text-lg leading-relaxed">
            Baja la aguja, sube el volumen y desconéctate. Tu música no debería vivir solo en tu teléfono.
            Encuentra el disco que te eriza la piel, el tocadiscos para hacerlo sonar como se debe
            y todo lo que necesitas para que tu espacio respire música.
          </p>
        </div>

      </div>
      <!-- Decorative separator -->
      <div class="mt-10 flex items-center gap-4">
        <div class="h-px flex-1 bg-gradient-to-r from-[#802020] via-surface-bright to-transparent"></div>
        <i class="fas fa-record-vinyl text-primary opacity-40"></i>
      </div>
    </div>

    <!-- Product Grid -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4 gap-md">
        {productosOrdenados.map(producto => <ProductCard {producto} />)}
      </div>
    </div>
  </section>
  <!-- END: #vinilos -->

  <!-- ============================================================ -->
  <!-- BEGIN: #galeria — Galería de Fotos                           -->
  <!-- ============================================================ -->
  <section id="galeria" class="scroll-mt-24 bg-surface">
    <!-- Section Header -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-10">
      <div class="text-center max-w-2xl mx-auto">
        <span class="text-[#802020] font-condensed font-semibold tracking-[0.3em] text-xs uppercase block mb-3">
          <i class="fas fa-camera mr-2"></i>Nuestra tienda
        </span>
        <h2 class="font-display font-bold uppercase text-on-surface mb-4"
          style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.05; letter-spacing: -0.02em;">
          Galería de <span class="text-primary">Fotos</span>
        </h2>
        <p class="text-on-surface-variant text-base leading-relaxed">
          Un vistazo a lo que nos define. Música, textura, carácter —
          cada imagen captura la esencia de Vinilovers.
        </p>
      </div>
      <div class="mt-10 flex items-center gap-4">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-surface-bright to-transparent"></div>
        <i class="fas fa-camera text-primary opacity-40"></i>
        <div class="h-px flex-1 bg-gradient-to-r from-surface-bright to-transparent"></div>
      </div>
    </div>

    <!-- Masonry Gallery Grid -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
      <div class="gallery-masonry">

        <!-- Item 1 — Tienda foto 1 -->
        <div class="gallery-item gallery-item--tall group overflow-hidden border border-surface-bright relative">
          <img src="/tienda_vinilovers (1).jpg"
            alt="Tienda Vinilovers" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-500 flex items-end p-4 opacity-0 group-hover:opacity-100">
            <span class="text-white text-xs font-condensed uppercase tracking-widest">Vinilovers · Nuestra tienda</span>
          </div>
        </div>

        <!-- Item 2 — Tienda foto 2 -->
        <div class="gallery-item group overflow-hidden border border-surface-bright relative">
          <img src="/tienda_vinilovers (2).jpg"
            alt="Interior Vinilovers" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-500 flex items-end p-4 opacity-0 group-hover:opacity-100">
            <span class="text-white text-xs font-condensed uppercase tracking-widest">Vinilovers · Interior</span>
          </div>
        </div>

        <!-- Item 3 — Tienda foto 3 -->
        <div class="gallery-item group overflow-hidden border border-surface-bright relative">
          <img src="/tienda_vinilovers (3).jpg"
            alt="Colección Vinilovers" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-500 flex items-end p-4 opacity-0 group-hover:opacity-100">
            <span class="text-white text-xs font-condensed uppercase tracking-widest">Vinilovers · Colección</span>
          </div>
        </div>

        <!-- Item 4 — Ubicación de la tienda -->
        <div class="gallery-item gallery-item--tall group overflow-hidden border border-surface-bright relative">
          <img src="/ubicacion_de_tienda_vinilovers.webp"
            alt="Ubicación Vinilovers" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-500 flex items-end p-4 opacity-0 group-hover:opacity-100">
            <span class="text-white text-xs font-condensed uppercase tracking-widest">Vinilovers · Ubicación</span>
          </div>
        </div>

      </div>

      <!-- CTA -->
      <div class="mt-12 text-center">
        <a href="https://www.instagram.com/viniloversbqto" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-3 font-condensed font-semibold uppercase tracking-widest text-sm border border-surface-bright px-8 py-3 text-on-surface-variant hover:text-primary hover:border-primary transition-all duration-300 rounded-sm">
          <i class="fab fa-instagram text-lg"></i> Ver más en Instagram
        </a>
      </div>
    </div>
  </section>
  <!-- END: #galeria -->

  <Footer />

</Layout>
