          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-500 flex items-end p-4 opacity-0 group-hover:opacity-100">
            <span class="text-white text-xs font-condensed uppercase tracking-widest">The Frontline · Prince</span>
          </div>
        </div>

        <!-- Item 6 — tocadiscos local image tall -->
        <div class="gallery-item gallery-item--tall group overflow-hidden border border-surface-bright relative">
          <img src="/TD00004-TOCADISCOS-TANLANIN-NEGRO.png"
            alt="Tocadiscos Tanlanin Negro" class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-700">
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-500 flex items-end p-4 opacity-0 group-hover:opacity-100">
            <span class="text-white text-xs font-condensed uppercase tracking-widest">Tanlanin Negro · Tocadiscos</span>
          </div>
        </div>

        <!-- Item 7 -->
        <div class="gallery-item group overflow-hidden border border-surface-bright relative">
          <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAVL_dU3zLjv1as_Am9IFfjUr5QaKK7WV5M5hTyun7svkd2MNifBAKEiMx7gxC7HG0fHyUPm_Kp254oQt8XLv3QtIXxzigY2vH1jCX7jcbpH3E4EAiwAIRZaCx1TqBZwRy_51oAX1MKPkfRvdD62vtoDk4X6Il__YZ9ROzaIgZO9mXP8MVt3Hy5-H1liTkZkPZNiCzfXW9NR7LiAIdNn-95eCGtOkU8quRdDec8nTybvfqjXGsBm-hRUB9ff94ytm15bRl1JEqq1ww"
            alt="Marshall Stanmore III" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-500 flex items-end p-4 opacity-0 group-hover:opacity-100">
            <span class="text-white text-xs font-condensed uppercase tracking-widest">Marshall Stanmore III</span>
          </div>
        </div>

        <!-- Item 8 -->
        <div class="gallery-item group overflow-hidden border border-surface-bright relative">
          <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuCqVCDf_vrAIxcpjxRKbKgxQY8WSzIZ6ysA8ePD6YBbazlJpekQa4P7TgxID4bkMnLS7R1BJ0VIQ7b_2XpAG__uuBSnzOecID-NFzATVdgdwr8iT0JsiWN7TBQgz_xlxbw0u7bKLzmMv1FaOlf5FlDfULNBeuD31UuILY9OU5EzPPVOCCUo4VJ2llcyH0CLQ16xy5mUCyF2m8qcMtQYGBVqPrctbjBcC5wQD1k66qon5Wes43h6qJ7H-XnwuCNYKg_NPpzFipV9XLE"
            alt="Nirvana Grunge Tee" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-500 flex items-end p-4 opacity-0 group-hover:opacity-100">
            <span class="text-white text-xs font-condensed uppercase tracking-widest">Grunge Classic · Nirvana</span>
          </div>
        </div>

        <!-- Item 9 — logo -->
        <div class="gallery-item group overflow-hidden border border-surface-bright relative bg-surface-container flex items-center justify-center p-8">
          <img src="/logo-cuadrado.jpg"
            alt="Vinilovers Logo" class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-700">
        </div>

      </div>

      <!-- CTA -->
      <div class="mt-12 text-center">
        <a href="https://www.instagram.com/viniloversbqto" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-3 font-condensed font-semibold uppercase tracking-widest text-sm border border-surface-bright px-8 py-3 text-on-surface-variant hover:text-primary hover:border-primary transition-all duration-300 rounded-sm">
          <i class="fab fa-instagram text-lg"></i> Ver más en Instagram
        </a>
      </div>
    </div>
  </section>
  <!-- END: #galeria -->

  <Footer />

</Layout>
