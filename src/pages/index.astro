---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import { getProductos } from '../lib/airtable.js';
import '../styles/global.css';

let productos = [];
try {
  productos = await getProductos();
} catch (e) {
  console.error('Error al obtener productos de Airtable:', e.message);
}
const destacados = productos.filter(p => p.destacado);
const resto = productos.filter(p => !p.destacado);
---

<Layout title="Vinilovers - Tienda de Vinilos">

  <Header />

  <!-- ============================================================ -->
  <!-- BEGIN: Hero Section                                           -->
  <!-- ============================================================ -->
  <section class="relative flex items-end pt-20 overflow-hidden" style="height: 85vh; min-height: 580px;">
    <div class="absolute inset-0 z-0 overflow-hidden">
      <video class="w-full h-full object-cover" autoplay muted loop playsinline poster="/portada-video-hero-home.svg">
        <source src="/video-fondo-hero.webm" type="video/webm">
        Tu navegador no soporta video HTML5.
      </video>
      <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/70 to-black/40"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full pb-24">
      <div class="max-w-5xl">
        <p class="font-condensed font-medium text-2xl md:text-3xl uppercase tracking-wide mb-6"
          style="line-height: 1.1; color: #a3211c;">No es solo música,</p>
        <h1 class="text-primary uppercase leading-[0.9] tracking-tight"
          style="font-family: 'Amnestia', sans-serif; font-size: clamp(3rem, 9vw, 7.5rem);">
          ES QUIENES<span class="block mt-6">SOMOS.</span>
        </h1>
        <div class="mt-8">
          <a href="#vinilos"
            class="inline-flex items-center gap-2 font-bold py-3 px-8 rounded-sm uppercase tracking-wider transition-colors text-sm border-2"
            style="color: #a3211c; border-color: #a3211c;"
            onmouseover="this.style.backgroundColor='#a3211c';this.style.color='#fff'"
            onmouseout="this.style.backgroundColor='transparent';this.style.color='#a3211c'">
            Ver colección <i class="fas fa-arrow-right"></i>
          </a>
        </div>
      </div>
    </div>
  </section>
  <!-- END: Hero Section -->

  <!-- ============================================================ -->
  <!-- BEGIN: Marquee                                                -->
  <!-- ============================================================ -->
  <div class="py-4 border-y overflow-hidden flex whitespace-nowrap bg-surface border-surface-container">
    <div class="animate-marquee flex gap-8 items-center text-primary font-display font-bold text-sm tracking-[0.2em] uppercase">
      <span>ROCK</span> <span class="text-[#802020]">•</span> <span>POP</span> <span class="text-[#802020]">•</span>
      <span>SALSA</span> <span class="text-[#802020]">•</span> <span>ACCESORIOS</span> <span class="text-[#802020]">•</span>
      <span>TOCADISCOS</span> <span class="text-[#802020]">•</span> <span>ROPA</span> <span class="text-[#802020]">•</span>
      <span>ROCK</span> <span class="text-[#802020]">•</span> <span>POP</span> <span class="text-[#802020]">•</span>
      <span>SALSA</span> <span class="text-[#802020]">•</span> <span>ACCESORIOS</span> <span class="text-[#802020]">•</span>
      <span>TOCADISCOS</span> <span class="text-[#802020]">•</span> <span>ROPA</span> <span class="text-[#802020]">•</span>
    </div>
    <div aria-hidden="true" class="animate-marquee flex gap-8 items-center text-primary font-display font-bold text-sm tracking-[0.2em] uppercase">
      <span class="ml-8">ROCK</span> <span class="text-[#802020]">•</span> <span>POP</span> <span class="text-[#802020]">•</span>
      <span>SALSA</span> <span class="text-[#802020]">•</span> <span>ACCESORIOS</span> <span class="text-[#802020]">•</span>
      <span>TOCADISCOS</span> <span class="text-[#802020]">•</span> <span>ROPA</span> <span class="text-[#802020]">•</span>
      <span>ROCK</span> <span class="text-[#802020]">•</span> <span>POP</span> <span class="text-[#802020]">•</span>
      <span>SALSA</span> <span class="text-[#802020]">•</span> <span>ACCESORIOS</span> <span class="text-[#802020]">•</span>
      <span>TOCADISCOS</span> <span class="text-[#802020]">•</span> <span>ROPA</span> <span class="text-[#802020]">•</span>
    </div>
  </div>
  <!-- END: Marquee -->

  <!-- ============================================================ -->
  <!-- BEGIN: #vinilos — Catálogo de Vinilos                        -->
  <!-- ============================================================ -->
  <section id="vinilos" class="scroll-mt-24 bg-background">
    <!-- Section Header -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-10">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
        <div class="max-w-2xl">
          <span class="text-[#802020] font-condensed font-semibold tracking-[0.3em] text-xs uppercase block mb-3">
            <i class="fas fa-compact-disc mr-2"></i>Colección
          </span>
          <h2 class="font-display font-bold uppercase text-on-surface mb-4"
            style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.05; letter-spacing: -0.02em;">
            Catálogo de <span class="text-primary">Vinilos</span>
          </h2>
          <p class="text-on-surface-variant text-base md:text-lg leading-relaxed">
            Cada surco cuenta una historia. Descubre nuestra colección curada de vinilos originales —
            desde rarezas de coleccionista hasta los clásicos que definieron una era.
            Sonido puro, sin filtros, tal como fue concebido para sonar.
          </p>
        </div>
        <div class="flex items-center gap-sm shrink-0">
          <span class="font-label-md text-on-surface-variant uppercase text-[11px] tracking-widest">Ordenar por:</span>
          <select class="bg-surface-container border border-outline-variant text-on-surface text-[11px] uppercase tracking-wider py-xs px-md focus:border-primary-container focus:ring-0 transition-all cursor-pointer">
            <option>Relevancia</option>
            <option>Novedades</option>
            <option>Precio: menor a mayor</option>
            <option>Precio: mayor a menor</option>
            <option>Ediciones raras</option>
          </select>
        </div>
      </div>
      <!-- Decorative separator -->
      <div class="mt-10 flex items-center gap-4">
        <div class="h-px flex-1 bg-gradient-to-r from-[#802020] via-surface-bright to-transparent"></div>
        <i class="fas fa-record-vinyl text-primary opacity-40"></i>
      </div>
    </div>

    <!-- Product Grid -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4 gap-md">
        {destacados.map(producto => <ProductCard {producto} />)}
        {resto.map(producto => <ProductCard {producto} />)}
      </div>
    </div>
  </section>
  <!-- END: #vinilos -->

  <!-- ============================================================ -->
  <!-- BEGIN: #galeria — Galería de Fotos                           -->
  <!-- ============================================================ -->
  <section id="galeria" class="scroll-mt-24 bg-surface">
    <!-- Section Header -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-10">
      <div class="text-center max-w-2xl mx-auto">
        <span class="text-[#802020] font-condensed font-semibold tracking-[0.3em] text-xs uppercase block mb-3">
          <i class="fas fa-camera mr-2"></i>Nuestra tienda
        </span>
        <h2 class="font-display font-bold uppercase text-on-surface mb-4"
          style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.05; letter-spacing: -0.02em;">
          Galería de <span class="text-primary">Fotos</span>
        </h2>
        <p class="text-on-surface-variant text-base leading-relaxed">
          Un vistazo a lo que nos define. Música, textura, carácter —
          cada imagen captura la esencia de Vinilovers.
        </p>
      </div>
      <div class="mt-10 flex items-center gap-4">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-surface-bright to-transparent"></div>
        <i class="fas fa-camera text-primary opacity-40"></i>
        <div class="h-px flex-1 bg-gradient-to-r from-surface-bright to-transparent"></div>
      </div>
    </div>

    <!-- Masonry Gallery Grid -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
      <div class="gallery-masonry">

