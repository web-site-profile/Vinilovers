            alt="Led Zeppelin IV" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-500 flex items-end p-4 opacity-0 group-hover:opacity-100">
            <span class="text-white text-xs font-condensed uppercase tracking-widest">Led Zeppelin IV</span>
          </div>
        </div>

        <!-- Item 5 -->
        <div class="gallery-item group overflow-hidden border border-surface-bright relative">
          <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuA_ET4lo1fLHMtvtVVOhSela0CTeHfgtsd_e5EmkYSgwS3TW9pvAtfzjYIltY9UaMVxmTwJR1bUdfYT9iM0FOElAYzsL9P1gnIYzmJicXIGZ7RG5mxx3Ng8yfYH7g6nYZ8oxBrgxJxqE4eT2vkC0v3iF2lBSxh3rzywqGTMrwVsaA5e2WRm_uvbkuxpyDoxzyjLi4yWxioW_PXIks1rscPozIQ3COVz64Y_PiiXZCLo5yasqtqdjkZrF_8REmZfNK9l50o_s08vsqw"
